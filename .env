# ── Database ──────────────────────────────────────────────────────────────
# For Vercel: Use PostgreSQL connection string from Neon / Vercel Postgres
# Example: postgresql://username:password@ep-xxx.neon.tech/neondb?sslmode=require
# For local dev with SQLite (fallback): file:./dev.db
DATABASE_URL="postgresql://placeholder:placeholder@localhost:5432/paliwal_secure"

# ── JWT Secrets ──────────────────────────────────────────────────────────
# IMPORTANT: Set these in Vercel Environment Variables!
JWT_SECRET="paliwal-secure-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="paliwal-secure-jwt-refresh-secret-change-in-production"

# ── Google Analytics ────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID="G-WTQDXFZC5F"
